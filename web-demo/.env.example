# mock：无需密钥；openai：OpenAI；bailian：阿里云百炼
AI_PROVIDER=mock

# 仅当 AI_PROVIDER=openai 时填写
OPENAI_API_KEY=

# 可按账号可用模型调整；默认使用高性价比模型
OPENAI_MODEL=gpt-5-mini

# 阿里云百炼配置（AI_PROVIDER=bailian 时使用）
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：开启真实地点、地址与经纬度校验
AMAP_API_KEY=

PORT=8787
